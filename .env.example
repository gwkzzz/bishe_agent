# Shared
APP_ENV=local
LOG_LEVEL=INFO
TRACE_HEADER_NAME=X-Trace-Id

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_SECRET_KEY=change-me
SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Algorithm
ALGORITHM_HOST=0.0.0.0
ALGORITHM_PORT=8001
ALGORITHM_INTERNAL_TOKEN=change-me-internal-token
ALGORITHM_BASE_URL=http://localhost:8001

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=legal_assistant
MYSQL_USER=legal_app
MYSQL_PASSWORD=legal_password
MYSQL_ROOT_PASSWORD=root_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=legal_app
RABBITMQ_DEFAULT_PASS=legal_password
RABBITMQ_URL=amqp://legal_app:legal_password@localhost:5672/

# MinIO
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=evidence

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
RAG_USE_DATABASE=false
RAG_VECTOR_ENABLED=false
RAG_VECTOR_DIMENSION=64
RAG_MIN_RELEVANCE_SCORE=0.02

# Model gateway
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_API_KEY=change-me
CHAT_MODEL=placeholder-chat-model
EMBEDDING_MODEL=placeholder-embedding-model
RERANK_MODEL=placeholder-rerank-model

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
